<%- include('partials/header') %>

<% 
function formatTime(slot){
    let start = slot
    let end = slot + 1
    const suffix = start >= 12 ? "PM" : "AM"
    let h = start % 12
    if(h === 0) h = 12
    return `${h.toString().padStart(2,"0")} ${suffix}`
}
%>

<div class="profile-header">
    <div class="profile-avatar">
        <%= user.name.charAt(0) %>
    </div>
    <h1 class="profile-name"><%= user.name %></h1>
    
    <div class="profile-points">
        🏆 Total Points: <span><%= points %></span>
    </div>
</div>

<div class="profile-grid">

    <!-- Left Column: Settings -->
    <div>
        <h2 class="profile-section-title">Personal Information</h2>
        <div class="profile-card">
            <form action="/profile/update" method="POST">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" class="form-control" value="<%= user.email %>" disabled title="Email cannot be changed">
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="phone" class="form-control" value="<%= user.phone %>">
                </div>
                <div class="form-group">
                    <label>Address</label>
                    <input type="text" name="address" class="form-control" value="<%= user.address %>">
                </div>
                <button type="submit" class="btn btn-primary btn-block">Update Profile</button>
            </form>
        </div>

        <% if (user && user.password !== 'google_oauth_login') { %>
            <h2 class="profile-section-title">Security</h2>
            <div class="profile-card">
                <form action="/profile/change-password" method="POST">
                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" name="old_password" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" name="new_password" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" name="confirm_password" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block" style="background-color: #1d1d1f;">Change Password</button>
                </form>
            </div>
        <% } %>
    </div>

    <!-- Right Column: Bookings -->
    <div>
        <h2 class="profile-section-title">Upcoming Bookings</h2>
        <div class="profile-card">
            <% if (upcoming.length === 0) { %>
                <p style="color: #86868b; text-align: center;">No upcoming bookings.</p>
                <a href="/calendar" class="btn btn-primary btn-block" style="margin-top: 15px; text-align: center;">Book a Court</a>
            <% } else { %>
                <% upcoming.forEach(booking => { %>
                    <div class="booking-item">
                        <div class="booking-info">
                            <h4><%= booking.court_name %></h4>
                            <p><%= booking.booking_date %> | <%= formatTime(booking.slot) %></p>
                        </div>
                        <span style="color: var(--btn-primary); font-weight: 600;">Confirmed</span>
                    </div>
                <% }) %>
                <hr style="margin: 20px 0 15px;">
                <div class="cancellation-notice">
                    <strong>Cancellation Policy:</strong><br>
                    Cancellation must be processed manually by contacting an admin at least 3 hours before your booking. Refunds will be handled manually with a penalty of Rs.100 
                </div>
            <% } %>
        </div>

        <h2 class="profile-section-title">Booking History</h2>
        <div class="profile-card" id="booking-history-list">
            <% if (history.length === 0) { %>
                <p style="color: #86868b; text-align: center;">No past bookings.</p>
            <% } else { %>
                <% history.forEach(booking => { %>
                    <div class="booking-item">
                        <div class="booking-info">
                            <h4><%= booking.court_name %></h4>
                            <p><%= booking.booking_date %> | <%= formatTime(booking.slot) %></p>
                        </div>
                        <span style="color: #86868b; font-size: 13px;">Completed (+10 pts)</span>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>