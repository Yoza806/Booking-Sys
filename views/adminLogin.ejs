<%- include('partials/header') %>

<main>
    <div class="auth-container">
        <h2 class="auth-title">Admin Access</h2>
        
        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label for="username">Admin Email</label>
                <input type="email" id="username" name="email" class="form-control" autocomplete="username" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" class="form-control" autocomplete="current-password" required>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Log In</button>
        </form>

        <div class="divider">OR</div>
        <a href="/auth/google/admin" class="btn btn-block btn-google">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" class="google-icon">
            Sign in with Google
        </a>

        <div class="auth-footer">
            <a href="/">Return to Home</a>
        </div>
    </div>
</main>

<%- include('partials/footer') %>