<%- include('partials/header') %>

<div class="analytics-container">
    <div class="admin-header">
        <h1>Business Analytics</h1>
        <p>Monitor your business performance and customer insights.</p>
        <div class="btn-group">
            <a href="/admin" class="btn btn-secondary">← Back to Dashboard</a>
        </div>
    </div>

    <!-- Revenue & Bookings Overview -->
    <h2 class="section-title">Revenue & Bookings Overview</h2>
    <div class="analytics-grid">
        <div class="stat-card">
            <h3>Today's Revenue</h3>
            <span class="value">LKR <%= stats.today_revenue.toLocaleString() %></span>
            <span class="growth"><%= stats.today_bookings %> bookings today</span>
        </div>
        <div class="stat-card">
            <h3>This Week</h3>
            <span class="value">LKR <%= stats.week_revenue.toLocaleString() %></span>
            <% 
                let weekGrowth = 0;
                if (stats.prev_week_revenue > 0) {
                    weekGrowth = ((stats.week_revenue - stats.prev_week_revenue) / stats.prev_week_revenue * 100).toFixed(1);
                }
            %>
            <span class="growth <%= weekGrowth >= 0 ? 'up' : 'down' %>">
                <%= weekGrowth >= 0 ? '↑' : '↓' %> <%= Math.abs(weekGrowth) %>% vs last week
            </span>
        </div>
        <div class="stat-card">
            <h3>This Month</h3>
            <span class="value">LKR <%= stats.month_revenue.toLocaleString() %></span>
            <% 
                let monthGrowth = 0;
                if (stats.prev_month_revenue > 0) {
                    monthGrowth = ((stats.month_revenue - stats.prev_month_revenue) / stats.prev_month_revenue * 100).toFixed(1);
                }
            %>
            <span class="growth <%= monthGrowth >= 0 ? 'up' : 'down' %>">
                <%= monthGrowth >= 0 ? '↑' : '↓' %> <%= Math.abs(monthGrowth) %>% vs last month
            </span>
        </div>
    </div>

    <!-- Customer Insights -->
    <h2 class="section-title">Customer Insights</h2>
    <div class="analytics-grid">
        <div class="stat-card">
            <h3>Total Registered Users</h3>
            <span class="value"><%= userStats.total_users %></span>
        </div>
        <div class="stat-card">
            <h3>New Users (Last 30 Days)</h3>
            <span class="value"><%= userStats.new_users %></span>
        </div>
    </div>

    <div class="profile-grid" style="grid-template-columns: 1fr 1fr; max-width: 100%; margin-top: 20px;">
        <!-- Top 10 Customers -->
        <div class="analytics-section">
            <h3 class="section-title" style="margin-top: 0;">Top 10 Customers</h3>
            <div class="cart-list" style="max-height: none;">
                <% topCustomers.forEach((customer, index) => { %>
                    <div class="booking-item">
                        <div class="booking-info">
                            <h4><%= index + 1 %>. <%= customer.name %></h4>
                            <p><%= customer.email %> • <%= customer.bookings %> bookings</p>
                        </div>
                        <div style="font-weight: 600;">LKR <%= customer.spent.toLocaleString() %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Court Performance -->
        <div class="analytics-section">
            <h3 class="section-title" style="margin-top: 0;">Court Performance Ranking</h3>
            <div class="cart-list" style="max-height: none;">
                <% courtPerf.forEach((court, index) => { %>
                    <div class="booking-item">
                        <div class="booking-info">
                            <h4><%= index + 1 %>. <%= court.court_name %></h4>
                            <p><%= court.bookings %> total bookings</p>
                        </div>
                        <div style="font-weight: 600;">LKR <%= court.revenue.toLocaleString() %></div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Active Bookings Today -->
    <h2 class="section-title">Active Bookings Today</h2>
    <div class="analytics-section">
        <% if (activeToday.length === 0) { %>
            <p style="color: #86868b; text-align: center; padding: 20px;">No bookings for today yet.</p>
        <% } else { %>
            <div class="courts-grid">
                <% 
                   const courts = [...new Set(activeToday.map(b => b.court_name))];
                   courts.forEach(courtName => {
                %>
                    <div class="stat-card">
                        <h3 style="color: var(--btn-primary); margin-bottom: 15px;"><%= courtName %></h3>
                        <% activeToday.filter(b => b.court_name === courtName).forEach(b => { %>
                            <div style="display: flex; justify-content: space-between; font-size: 13px; border-bottom: 1px solid #f0f0f0; padding: 8px 0;">
                                <span>Slot <%= b.slot %>:00</span>
                                <span style="font-weight: 500;"><%= b.user_name %></span>
                            </div>
                        <% }) %>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>